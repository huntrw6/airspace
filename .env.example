# Generate both secrets before public deployment, for example:
# python -c "import secrets; print(secrets.token_urlsafe(48))"
AIRSPACE_ENVIRONMENT=production
AIRSPACE_DATABASE_URL=sqlite:////app/data/airspace.db
AIRSPACE_PUBLIC_URL=https://planes.example.com
AIRSPACE_PORT=8000
AIRSPACE_COOKIE_SECURE=true
AIRSPACE_ADMIN_PASSWORD=replace-with-a-long-random-password
AIRSPACE_SESSION_PEPPER=replace-with-an-independent-long-random-secret
AIRSPACE_POLL_INTERVAL_SECONDS=30
AIRSPACE_PROVIDER_ENABLED=true
AIRSPACE_MAX_REGIONS_PER_CYCLE=40
AIRSPACE_HISTORY_RETENTION_DAYS=60
AIRSPACE_INACTIVE_PROFILE_DAYS=365
AIRSPACE_INVALID_SUBSCRIPTION_RETENTION_DAYS=7
AIRSPACE_CLEANUP_INTERVAL_SECONDS=86400
AIRSPACE_RATE_LIMIT_WINDOW_SECONDS=60
AIRSPACE_RATE_LIMIT_PUBLIC_REQUESTS=120
AIRSPACE_RATE_LIMIT_MUTATION_REQUESTS=30
AIRSPACE_RATE_LIMIT_PROFILE_CREATIONS=10
# Set to 1 only when exactly one trusted reverse proxy is in front of Airspace.
AIRSPACE_TRUSTED_PROXY_HOPS=1
AIRSPACE_GEOCODING_ENABLED=true
AIRSPACE_GEOCODING_BASE_URL=https://nominatim.openstreetmap.org
# Set a truthful application/contact identifier when using public Nominatim.
AIRSPACE_GEOCODING_USER_AGENT=Airspace/0.1 (admin@example.com)
# Generate this pair once with:
# docker compose run --rm airspace python -m airspace.generate_vapid
# AIRSPACE_VAPID_PUBLIC_KEY=
# AIRSPACE_VAPID_PRIVATE_KEY=
# AIRSPACE_VAPID_SUBJECT=mailto:admin@example.com
# Optional Fernet key; otherwise encryption derives from AIRSPACE_SESSION_PEPPER.
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# AIRSPACE_PUSH_ENCRYPTION_KEY=
